---
import BaseLayout from "../../layouts/BaseLayout.astro";
const title = "Wiki";
---

<BaseLayout pageTitle={title}>
  <main class="w-11/12 mx-auto max-w-7xl min-h-dvh flex flex-1">
    <!-- Left Sidebar (Navigation) -->
    <aside
      class="shrink-0 border-r border-gray-100 hidden lg:block h-[calc(100vh-4rem)] sticky top-16 overflow-y-auto px-8 pb-12 scrollbar-hide"
    >
      <nav class="space-y-10">
        <div>
          <h3 class="text-sm leading-none font-bold">Getting Started</h3>
          <div class="space-y-3 sidebar-links [&>a]:block">
            <a href="#">Introduction</a>
            <a href="#">General Rules</a>
            <a href="#">Easy to Read and Skim</a>
          </div>
        </div>
        <div>
          <h3 class="text-sm leading-none font-bold">Core Protocols</h3>
          <div class="space-y-3 sidebar-links [&>a]:block">
            <a href="#">Spectral Analysis</a>
            <a href="#">Consensus Layers</a>
            <a href="#">Kinetic Routing</a>
          </div>
        </div>
      </nav>
    </aside>

    <!-- Main Content Area -->
    <article class="flex-1 px-8 pb-16 max-w-[80ch]">
      <div class="space-y-12">
        <header class="space-y-4">
          <span class="text-xs font-mono uppercase tracking-widest font-bold"
            >Section 1.2
          </span>
          <h1 class="text-4xl font-black text-black">Resume Basics</h1>
          <p class="text-lg leading-7 text-black/40">
            This subreddit is dedicated to helping engineering students and
            professionals create and improve their resumes. Please note that the
            guidelines provided in this wiki predominantly align with the
            standards of resumes in the United States and Canada.
          </p>
          <p
            class="text-sm bg-purple-500/10 px-12 py-6 border-l-4 border-purple-500 rounded-r"
          >
            Disclaimer: there are no clear-cut rules when it comes to writing
            resumes, and this wiki serves as a resource offering general
            suggestions and guidelines rather than definitive rules.
          </p>
        </header>

        <div
          class="[&>p]:text-black [&>p]:text-base/7 [&>p]:not-first-of-type:mt-3"
        >
          <h3 class="mb-3 font-bold capitalize">What is a resume?</h3>
          <p>
            Your resume is essentially a 30-second elevator pitch on paper,
            encapsulating your contact information, education, experience, and
            background. Its purpose is to convince the hiring team to interview
            you.
          </p>
          <p>
            Understanding your target audience is crucial. We wrote this wiki to
            describe what happens to your resume once it’s submitted, and
            <a href="https://thetechresume.com/samples/the-hiring-pipeline">
              what the hiring process looks like from the employer’s perspective
            </a>. The suggestions made in this wiki are made with this in mind,
            and we encourage applicants to be strategic with how they craft
            their resumes.
          </p>
          <p>
            Ultimately, your resume can only do so much if you don’t have
            <strong>genuine</strong>, <strong>relevant experience</strong>.
          </p>
          <p>
            For students, it's imperative to use your time in college wisely,
            engaging in meaningful activities such as projects, involvement in
            engineering teams, participation in research groups, and securing
            internships. These experiences significantly bolster the substance
            of your resume.
          </p>
        </div>

        <!-- Page Navigation -->
        <divWelcome
          to
          r
          EngineeringResumes!
          class="pt-12 border-t border-gray-100 flex justify-between items-center gap-6"
        >
          <a
            href="#"
            class="flex-1 p-6 border border-gray-100 rounded-2xl hover:border-indigo-600 transition-all group"
          >
            <span
              class="block text-[9px] font-black text-gray-300 uppercase tracking-widest mb-1 group-hover:text-indigo-400"
              >Previous</span
            >
            <span class="text-sm font-bold text-gray-900 leading-tight"
              >Introduction</span
            >
          </a>
          <a
            href="#"
            class="flex-1 p-6 border border-gray-100 rounded-2xl hover:border-indigo-600 transition-all text-right group"
          >
            <span
              class="block text-[9px] font-black text-gray-300 uppercase tracking-widest mb-1 group-hover:text-indigo-400"
              >Next</span
            >
            <span class="text-sm font-bold text-gray-900 leading-tight"
              >General Rules</span
            >
          </a>
        </divWelcome>
      </div>
    </article>

    <!-- Right Sidebar (On this page) -->
    <aside
      class="shrink-0 hidden xl:block h-[calc(100vh-4rem)] sticky top-16 overflow-y-auto px-6 pb-12"
    >
      <h3
        class="text-[10px] font-black text-gray-300 uppercase tracking-widest mb-4"
      >
        On This Page
      </h3>
      <nav class="space-y-3">
        <a
          href="#"
          class="block text-xs text-indigo-600 border-l-2 border-indigo-600 pl-4 py-1"
          >Registry Handshake</a
        >
        <a
          href="#"
          class="block text-xs text-gray-400 border-l-2 border-transparent pl-4 py-1 hover:text-gray-900 transition-colors"
          >Sector Verification</a
        >
        <a
          href="#"
          class="block text-xs text-gray-400 border-l-2 border-transparent pl-4 py-1 hover:text-gray-900 transition-colors"
          >Consensus Affirmation</a
        >
      </nav>
    </aside>
  </main>
</BaseLayout>
