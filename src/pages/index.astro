---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "Home";
---

<BaseLayout pageTitle={title}>
  <section class="">
    <span class="flex flex-col-reverse">
      <h1 class="text-4xl/16 font-semibold capitalize">
        Build a Resume That Actually Works!
      </h1>
      <p class="text-sm">Welcome to r/EngineeringResumes!</p>
    </span>
    <p class="text-lg/8 max-w-3xl text-balance">
      Follow the gold-standard engineering rules to pass the robots (ATS) and
      impress hiring managers. A minimal, ATS-friendly template using
      r/EngineeringResumes wiki.
    </p>
    <div class="flex items-center gap-4 mt-10">
      <a
        href="https://www.reddit.com/r/EngineeringResumes/wiki/index/"
        class="text-sm/11 font-semibold capitalize rounded bg-black text-white px-4 hover:bg-black/80 py-0 transition-colors hover:underline"
      >
        Read the Wiki
      </a>

      <a
        href="/checklist"
        class="text-sm/11 font-semibold capitalize rounded bg-black/10 text-black px-4 hover:bg-black/15 py-0 transition-colors hover:underline"
      >
        Use the Checklist
      </a>
    </div>
  </section>
</BaseLayout>
